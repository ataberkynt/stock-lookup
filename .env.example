# Your Shopify store — "mystore", "mystore.myshopify.com" or the full URL all work
SHOPIFY_STORE=mystore.myshopify.com

# Admin API access token from a custom app (starts with shpat_...)
# Required scopes: read_products, read_inventory, read_locations
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The location whose stock you want to show. Numeric id or full gid both work.
#   1234567890  OR  gid://shopify/Location/1234567890
SHOPIFY_LOCATION_ID=1234567890

# Optional. Defaults to 2025-01.
# SHOPIFY_API_VERSION=2025-01

# Optional. If set, the whole site is protected with HTTP basic auth.
# Username can be anything; the password must match this value.
# APP_PASSWORD=some-shared-password

# Railway sets PORT automatically; only needed for local runs.
# PORT=3000
